# Droid Cloud PostgreSQL/PostGIS migration settings
# Copy the relevant values into backend/.env after PostgreSQL is installed.

DB_BACKEND=postgres
DEV_MODE=False

# Keep SQLite read-only for migration. Do not point this at a copied or edited file unless intentional.
SQLITE_DATABASE_URL=sqlite:///file:D:/1_Portal_Workflows_development/Droid Survair Cloud Portal/Project_Data/droid_cloud_prod.db?mode=ro&uri=true

# Replace CHANGE_ME before use.
POSTGRES_DATABASE_URL=postgresql+psycopg2://droid_user:CHANGE_ME@localhost:5432/droid_master_suite
POSTGIS_SRID=4326
